// Shairport Sync Configuration Template for pinstrel
// Recommended location: /etc/shairport-sync.conf

general = {
  name = "Pinstrel";   // The name that will show up on your iOS/Mac AirPlay menu
  output_backend = "pipe";     // Route audio to the named pipe
};

sessioncontrol = {
  // Hooks called when playback starts and ends
  run_this_before_play_begins = "/usr/local/bin/pinstrel start";
  run_this_after_play_ends = "/usr/local/bin/pinstrel stop";

  // Timeout in seconds after audio stops before the session officially ends
  session_timeout = 10;
};

pipe = {
  name = "/tmp/shairport-sync-audio";  // Named pipe path (must match pinstrel config.toml)
  output_rate = 44100;                 // AirPlay native sample rate (pinstrel resamples 44.1kHz -> 48kHz in Go)
  output_format = "S16_LE";            // 16-bit Signed Little-Endian PCM
  output_channels = 2;                 // Stereo
};
